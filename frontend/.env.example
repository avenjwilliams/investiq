# Copy this file to .env.local (gitignored) for local overrides, or set
# REACT_APP_API_URL in your hosting provider's project settings (e.g.
# Vercel's Environment Variables UI) for production.
#
# CRA only inlines env vars prefixed with REACT_APP_, and only at build
# time — changing this requires a rebuild, not just a restart.

# Local dev default is http://localhost:8000 if unset.
# Production example: https://investiq-api.onrender.com
REACT_APP_API_URL=
