# Copy this file to .env and fill in real values. .env is gitignored — never
# commit it. This is the backend's env file (project root, same place
# main.py's load_dotenv() looks).

# Required for the Sentiment Feed's live news fetch (NewsAPI.org).
NEWS_API_KEY=your_newsapi_key_here

# Local dev: leave unset — defaults to a local SQLite file.
# Production: set to a Postgres connection string (e.g. from Neon).
# Example: postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/investment?sslmode=require
DATABASE_URL=

# Comma-separated list of frontend origins allowed to call this API.
# Local dev default (http://localhost:3000) is used if unset.
# Production example: https://investiq.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Render (and most PaaS hosts) set PORT automatically — leave unset locally.
PORT=

# 1 = uvicorn autoreload on (local dev). Set to 0 in production.
DEV_MODE=1
