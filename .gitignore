# Secrets — never commit real credentials
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
.venv/
venv/
env/

# SQLite database (local dev only — production uses Postgres via DATABASE_URL)
backend/data/*.db
backend/data/*.db-journal

# Local runtime state — each environment (local dev, Render, etc.) should
# track its own fetch history, not inherit a frozen value from git.
backend/ingestion/.last_fetch.json

# Trained model artifacts — regenerate via POST /forecast/transformer/train-all
# rather than committing binary/environment-specific files to the repo.
# Metrics JSON files are kept (not ignored) — they're the validation
# evidence documented in the README and are worth having in version control.
backend/models/*.keras
backend/models/*.pkl
backend/models/transformer_ticker_index.json

# Node / React
frontend/node_modules/
frontend/build/
frontend/.env.local
npm-debug.log*

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp
