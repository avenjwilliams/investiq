# Secrets — never commit real credentials
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
.venv/
venv/
env/

# SQLite database (local dev only — production uses Postgres via DATABASE_URL)
backend/data/*.db
backend/data/*.db-journal

# Local runtime state — each environment (local dev, Render, etc.) should
# track its own fetch history, not inherit a frozen value from git.
backend/ingestion/.last_fetch.json

# Trained model artifacts (multivariate_transformer.keras, transformer_scaler.pkl,
# transformer_ticker_index.json) are intentionally NOT ignored and ARE committed.
# Originally excluded on the assumption they'd be regenerated via
# POST /forecast/transformer/train-all against the hosted backend — but Render's
# free tier only has 512MB RAM, and training across all 40 tickers in-process
# OOMs the instance. The model is tiny (~200KB) and doesn't change often, so
# it's simpler and more reliable to train locally and commit the result than to
# train inside a memory-constrained container. Retrain locally and re-commit
# these files when the model changes.

# Node / React
frontend/node_modules/
frontend/build/
frontend/.env.local
npm-debug.log*

# OS / editor cruft
.DS_Store
.vscode/
.idea/
*.swp
